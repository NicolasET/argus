{
  "name": "argus-mcp",
  "version": "0.1.0",
  "description": "An MCP server that gives AI eyes on your frontend — screenshots + rendered DOM at any viewport, for infinite visual iteration.",
  "type": "module",
  "bin": {
    "argus-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "capture": "node scripts/capture.ts",
    "login": "node scripts/login.ts",
    "postinstall": "playwright install chromium firefox webkit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "playwright",
    "frontend",
    "screenshot",
    "ai",
    "visual-iteration"
  ],
  "author": "Nicolas",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "playwright": "^1.61.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3"
  }
}
